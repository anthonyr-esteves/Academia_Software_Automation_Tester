      "item": [
        {
          "name": "TC-001 | POST Criar Conta A (válida)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// TC-001: Criar conta com dados válidos",
                  "pm.test('TC-001 | Status deve ser 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('TC-001 | Response deve conter id', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('id');",
                  "    pm.collectionVariables.set('accountIdA', json.id);",
                  "    console.log('Conta A criada com ID:', json.id);",
                  "});",
                  "",
                  "pm.test('TC-001 | Nome deve ser João Silva', function () {",
                  "    pm.expect(pm.response.json().name).to.eql('João Silva');",
                  "});",
                  "",
                  "pm.test('TC-001 | Saldo inicial deve ser 1000', function () {",
                  "    pm.expect(pm.response.json().balance).to.eql(1000);",
                  "});",
                  "",
                  "pm.test('TC-001 | Response deve conter createdAt', function () {",
                  "    pm.expect(pm.response.json()).to.have.property('createdAt');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"João Silva\",\n  \"email\": \"joao@email.com\",\n  \"cpf\": \"111.111.111-11\",\n  \"initialBalance\": 1000\n}"
